# Copy to .env and fill in. Freqtrade reads FREQTRADE__<SECTION>__<KEY> env vars
# as config overrides, so no secret ever needs to live in config*.json.

# Kraken API — create with TRADE-ONLY permissions, NO withdrawal rights,
# and IP-whitelist your VPS/home IP in Kraken's key settings.
# Not needed for dry-run or backtesting; required only at the live gate.
FREQTRADE__EXCHANGE__KEY=
FREQTRADE__EXCHANGE__SECRET=

# Telegram bot control (optional; set ENABLED to true once token/chat_id filled)
FREQTRADE__TELEGRAM__ENABLED=false
FREQTRADE__TELEGRAM__TOKEN=
FREQTRADE__TELEGRAM__CHAT_ID=

# WebUI (FreqUI) login. JWT_SECRET_KEY and WS_TOKEN must be >=32 chars —
# generate with: python -c "import secrets; print(secrets.token_hex(32))"
FREQTRADE__API_SERVER__USERNAME=solsignal
FREQTRADE__API_SERVER__PASSWORD=
FREQTRADE__API_SERVER__JWT_SECRET_KEY=
FREQTRADE__API_SERVER__WS_TOKEN=

# Shared secret TradingView must include in its webhook JSON payload.
# generate with: python -c "import secrets; print(secrets.token_urlsafe(24))"
RELAY_SECRET=
