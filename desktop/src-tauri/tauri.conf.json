{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SolSignal Controller",
  "version": "0.1.0",
  "identifier": "com.solsignal.controller",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "title": "SolSignal Controller",
        "width": 520,
        "height": 640,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "pubkey": "REPLACE_WITH_YOUR_TAURI_UPDATER_PUBLIC_KEY",
      "endpoints": [
        "https://github.com/REPLACE_OWNER/solsignal/releases/latest/download/latest.json"
      ]
    }
  }
}
