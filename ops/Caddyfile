# Voltra hardened ingress (stock Caddy 2).
#
# Single TLS-terminating front door. Caddy auto-provisions Let's Encrypt certs
# when VOLTRA_DOMAIN is a real public domain (ports 80/443 reachable); for
# local use (VOLTRA_DOMAIN=localhost) it uses its internal CA — TLS is still
# on, just self-signed. This also gives the TradingView relay a real HTTPS URL.
#
# .env:  VOLTRA_DOMAIN=trade.example.com   CADDY_ACME_EMAIL=you@example.com
#
# Optional hardening not enabled here (need a config choice / plugin):
#   - basic_auth on the API routes (generate a bcrypt hash; FreqUI already has
#     its own JWT auth so this is belt-and-suspenders)
#   - rate_limit (requires a custom Caddy build with the caddy-ratelimit module)

{
	admin off
	email {$CADDY_ACME_EMAIL:admin@example.com}
	order rate_limit before basic_auth
}

(secure_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		-Server
	}
}

{$VOLTRA_DOMAIN:localhost} {
	# Bind all container interfaces so the published port reaches Caddy even
	# when the site name is "localhost" (which otherwise binds loopback-only).
	bind 0.0.0.0
	import secure_headers

	# Per-IP rate limit (needs the caddy-ratelimit module — see Caddy.Dockerfile).
	# 120 requests/min/IP protects the public endpoint from abuse/DDoS.
	rate_limit {
		zone perip {
			key {remote_host}
			events 120
			window 1m
		}
	}

	# FreqUI (bot #1) — full control panel, has its own JWT login
	handle_path /frequi/* {
		reverse_proxy freqtrade:8080
	}

	# Per-bot REST API routes for the WordPress monitor (and any external
	# monitor). Each strips its prefix and proxies to that bot's :8080, so the
	# bot API lands at https://<domain>/bot/<name>/api/v1/... The bots keep
	# their own JWT auth. Set the plugin's Bots list to these URLs.
	handle_path /bot/dry/* {
		reverse_proxy freqtrade:8080
	}
	handle_path /bot/cross/* {
		reverse_proxy freqtrade-cross:8080
	}
	handle_path /bot/webhook/* {
		reverse_proxy freqtrade-webhook:8080
	}

	# TradingView webhook relay — auth is the relay's shared secret, so no
	# extra gate here; TLS + headers still apply. Point TradingView at
	#   https://<domain>/webhook/webhook
	handle_path /webhook/* {
		reverse_proxy webhook-relay:8090
	}

	# Custom read-only dashboard at the root
	handle {
		reverse_proxy dashboard:80
	}
}
